# Shared by both apps. Copy to .env (root) and into each app as .env.local if needed.

# --- Database ---
# Demo: SQLite (zero setup). Production: swap to a Postgres URL (Neon/Supabase) and
# change provider in packages/db/prisma/schema.prisma from "sqlite" to "postgresql".
DATABASE_URL="file:../packages/db/prisma/dev.db"

# --- Stripe (TEST keys) ---
# Leave BLANK to run the demo with a simulated checkout (no real Stripe needed).
# Fill with sk_test_... / pk_test_... to use real Stripe test mode.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- URLs ---
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# --- CRM demo auth (replace with real auth for production) ---
ADMIN_PASSWORD="demo1234"
