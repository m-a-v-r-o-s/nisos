# Shared by both apps. Copy to .env (root) and into each app as .env.local if needed.

# --- Database (PostgreSQL) ---
# Both apps share one Postgres. On Railway, set this to the Postgres service's
# DATABASE_URL. Locally, run one (e.g. `docker run -d -e POSTGRES_PASSWORD=postgres \
#   -e POSTGRES_DB=rentals -p 5432:5432 postgres:16-alpine`) and use its URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rentals?schema=public"

# --- Stripe (TEST keys) ---
# Leave BLANK to run the demo with a simulated checkout (no real Stripe needed).
# Fill with sk_test_... / pk_test_... to use real Stripe test mode.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- URLs ---
NEXT_PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"

# --- CRM demo auth (replace with real auth for production) ---
ADMIN_PASSWORD="demo1234"
